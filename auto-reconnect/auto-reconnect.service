[Unit]
Description=Auto-Reconnect Daemon - 断线自动重连守护进程
Documentation=file:///etc/auto-reconnect/README.md
After=network.target network-online.target openclaw-gateway.service
Wants=network-online.target

[Service]
Type=simple
User=root
Group=root
ExecStart=/usr/local/bin/auto-reconnect-daemon
ExecReload=/bin/kill -HUP $MAINPID
PIDFile=/var/run/auto-reconnect.pid
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=auto-reconnect

# 环境变量
Environment="SMTP_PASS="
Environment="PYTHONUNBUFFERED=1"

# 工作目录
WorkingDirectory=/var/lib/auto-reconnect

# 资源限制
LimitNOFILE=65535
LimitNPROC=4096

# 安全设置
NoNewPrivileges=false
ProtectSystem=false
ProtectHome=false

[Install]
WantedBy=multi-user.target
