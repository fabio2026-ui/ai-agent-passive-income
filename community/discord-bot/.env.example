# Discord Bot Environment Variables

# Required - Get from Discord Developer Portal
DISCORD_TOKEN=your_bot_token_here

# Optional - Channel IDs (Enable Developer Mode in Discord to copy IDs)
# Right-click channel → Copy Channel ID
WELCOME_CHANNEL_ID=
NEWS_CHANNEL_ID=

# Optional - Role IDs (Enable Developer Mode in Discord to copy IDs)
# Server Settings → Roles → Right-click role → Copy Role ID
AUTO_ROLE_ID=

# Bot Settings
BOT_PREFIX=!

# Note: Never share your .env file or commit it to version control!