# =============================================================================
# SecureScan API - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# =============================================================================

# =============================================================================
# Application
# =============================================================================
ENVIRONMENT=development
SECRET_KEY=your-super-secret-random-string-at-least-32-characters
FRONTEND_URL=http://localhost:3000
PORT=8000
HOST=0.0.0.0

# =============================================================================
# Database
# =============================================================================
# Railway/Render will provide this automatically
# For local development, use:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/apiscanner

# =============================================================================
# Redis (for queues and caching)
# =============================================================================
# Railway/Render will provide this automatically
# For local development, use:
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Stripe (Required for payments)
# =============================================================================
# Get your keys from: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Webhook secret (from Stripe Dashboard -> Developers -> Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs (create these in Stripe Dashboard -> Products)
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_TEAM_MONTHLY=price_...
STRIPE_PRICE_TEAM_YEARLY=price_...

# =============================================================================
# CORS
# =============================================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://yourdomain.com

# =============================================================================
# Email (Optional - for notifications)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@securescan.dev

# =============================================================================
# Limits
# =============================================================================
MAX_SCANS_PER_MONTH_FREE=3
MAX_ENDPOINTS_PER_SCAN_FREE=50

# =============================================================================
# Monitoring (Optional)
# =============================================================================
SENTRY_DSN=
LOG_LEVEL=info
