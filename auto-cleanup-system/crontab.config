# 智能磁盘清理系统 - 定时任务配置
# 复制以下内容到 crontab -e

# 每分钟检查磁盘空间 (监控服务已内置此功能，如使用监控服务则不需要)
# * * * * * /root/.openclaw/workspace/auto-cleanup-system/disk-monitor.sh check >> /root/.openclaw/workspace/auto-cleanup-system/cleanup.log 2>&1

# 每小时生成一次状态报告
0 * * * * /root/.openclaw/workspace/auto-cleanup-system/disk-monitor.sh status >> /root/.openclaw/workspace/auto-cleanup-system/cleanup.log 2>&1

# 每天凌晨3点执行深度清理
0 3 * * * /root/.openclaw/workspace/auto-cleanup-system/disk-monitor.sh p1 >> /root/.openclaw/workspace/auto-cleanup-system/cleanup.log 2>&1

# 每周日凌晨执行完整检查并发送报告
0 0 * * 0 /root/.openclaw/workspace/auto-cleanup-system/disk-monitor.sh status >> /root/.openclaw/workspace/auto-cleanup-system/cleanup.log 2>&1

# 保留最近7天的日志，每周一清理旧日志
0 1 * * 1 find /root/.openclaw/workspace/auto-cleanup-system -name "*.log.old" -mtime +7 -delete 2>/dev/null
