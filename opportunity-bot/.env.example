# Reddit API 配置
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USERNAME=your_username
REDDIT_PASSWORD=your_password
REDDIT_USER_AGENT=OpportunityBot/1.0 by u/your_username

# 邮件通知配置
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_TO=recipient@example.com

# 钉钉/飞书/Slack 通知（可选）
DINGTALK_WEBHOOK=
FEISHU_WEBHOOK=
SLACK_WEBHOOK=

# 通用配置
NODE_ENV=development
LOG_LEVEL=info
DATA_DIR=./data
REPORTS_DIR=./reports
LOGS_DIR=./logs

# 监控配置
TRENDS_GEO=US
TRENDS_TIME_RANGE=today 7-d
PRICING_CHECK_INTERVAL=4
REDDIT_CHECK_INTERVAL=1
RSS_CHECK_INTERVAL=2
