# ContentAI 环境变量配置模板
# 复制此文件为 .env 并填入你的实际密钥
# ⚠️ 不要提交 .env 到代码仓库!

# ============================================
# 应用配置
# ============================================
APP_URL=https://contentai.yourdomain.com
APP_NAME=ContentAI
EMAIL_FROM=noreply@contentai.com

# ============================================
# Moonshot AI API (必需)
# 获取地址: https://platform.moonshot.cn/
# ============================================
MOONSHOT_API_KEY=sk-your-moonshot-api-key-here

# ============================================
# Coinbase Commerce (主要支付方式)
# 获取地址: https://commerce.coinbase.com/settings
# ============================================
COINBASE_API_KEY=your-coinbase-api-key
COINBASE_WEBHOOK_SECRET=your-coinbase-webhook-secret

# ============================================
# Stripe (推荐支付方式 - 你有这个！)
# 获取地址: https://dashboard.stripe.com/apikeys
# ============================================
STRIPE_SECRET_KEY=sk_test_... or sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_... or pk_live_...

# ============================================
# NowPayments (备选支付方式)
# 获取地址: https://nowpayments.io/
# ============================================
NOWPAYMENTS_API_KEY=your-nowpayments-api-key
NOWPAYMENTS_WEBHOOK_SECRET=your-nowpayments-webhook-secret

# ============================================
# Resend 邮件服务 (必需)
# 获取地址: https://resend.com/
# ============================================
RESEND_API_KEY=re_your-resend-api-key

# ============================================
# Reddit API (可选 - 用于自动获客)
# 获取地址: https://www.reddit.com/prefs/apps
# ============================================
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USERNAME=your-reddit-username
REDDIT_PASSWORD=your-reddit-password

# ============================================
# Twitter/X API (可选 - 用于自动获客)
# 获取地址: https://developer.twitter.com/
# ============================================
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_SECRET=your-twitter-access-token-secret
TWITTER_BEARER_TOKEN=your-twitter-bearer-token
